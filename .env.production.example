# =============================================================================
# Extend Global (EG) — 生产环境配置模板
# =============================================================================
# 使用方法：
#   1. 复制此文件：cp .env.production.example .env
#   2. 填入真实值
#   3. 重新构建：docker compose -f docker-compose.prod.yml up -d --build
#
# ⚠️ Docker Compose 默认读取项目根目录下的 .env 文件（不是 .env.production）
# ⚠️ .env 包含敏感信息，已被 .gitignore 忽略，请勿将真实密钥提交到 Git 仓库！
# =============================================================================

# ─── 核心配置（必填）──────────────────────────────────────────────────────

# 数据库路径（Docker 容器内路径，无需修改）
DATABASE_URL=file:/app/data/production.db

# JWT 密钥（请替换为您自己生成的随机字符串）
# 生成方法：在终端运行 openssl rand -hex 32
JWT_SECRET=请替换为您生成的随机字符串

# ─── 管理员账户（首次启动时创建）────────────────────────────────────────

ADMIN_BOOTSTRAP_EMAIL=您的邮箱@example.com
ADMIN_BOOTSTRAP_NAME=您的姓名
ADMIN_BOOTSTRAP_PASSWORD=请设置一个强密码

# ─── 域名配置（根据您的实际域名修改）────────────────────────────────────

# 三大核心门户
ADMIN_APP_URL=https://admin.extendglobal.ai
PORTAL_APP_URL=https://app.extendglobal.ai
WORKER_APP_URL=https://worker.extendglobal.ai

# CP 白标通配符域名（*.extendglobal.ai）
# 前端通过 isCpDomain() 自动检测 CP 子域名并加载品牌
# 无需额外配置，Nginx 通配符 server 块已处理

# ─── 阿里云 OSS 对象存储（用于文件上传、Logo、合同等）──────────────────

# 注意: OSS_REGION 使用阿里云原始格式 (oss-ap-southeast-3)，代码会自动处理兼容性
# 注意: OSS_ENDPOINT 使用阿里云原始格式，代码会自动转换为S3兼容格式
OSS_ACCESS_KEY_ID=your_oss_access_key_id
OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret
OSS_REGION=oss-ap-southeast-3
OSS_BUCKET=your_bucket_name
OSS_ENDPOINT=https://oss-ap-southeast-3.aliyuncs.com

# ─── 邮件配置（用于发送通知邮件、邀请链接、密码重置等）──────────────────

# 可使用阿里云邮件推送服务或其他 SMTP 服务
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=465
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_FROM=no-reply@extendglobal.ai
EMAIL_ADMIN=admin@extendglobal.ai

# ─── AI 配置（可选，用于智能助手功能）──────────────────────────────────

# 阿里云 DashScope（通义千问）API Key
DASHSCOPE_API_KEY=your_dashscope_api_key
